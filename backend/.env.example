# ─── Banco de Dados ───────────────────────────────────────────
POSTGRES_DB=plantao_pet
POSTGRES_USER=plantao
POSTGRES_PASSWORD=troque_esta_senha

# Para rodar com Docker use @postgres; local use @localhost
DATABASE_URL=postgresql://plantao:troque_esta_senha@postgres:5432/plantao_pet

# ─── API ──────────────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
JWT_SECRET=gere_um_segredo_forte_aqui
JWT_EXPIRES_IN=7d
PORT=3000

# ─── Kafka ────────────────────────────────────────────────────
KAFKAJS_NO_PARTITIONER_WARNING=1
# Docker: kafka:29092 | Local: localhost:9092
KAFKA_BROKER=kafka:29092

# ─── Kafka UI ─────────────────────────────────────────────────
KAFKA_UI_PORT=8080
KAFKA_CLUSTER_NAME=plantao-pet
